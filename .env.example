# Copy this file to `.env` and fill in your Mesh Sandbox credentials
# (from the Mesh Dashboard you requested access to).

MESH_CLIENT_ID=your_client_id_here
MESH_CLIENT_SECRET=your_client_secret_here

# Sandbox API host — leave as-is for the take-home test
MESH_BASE_URL=https://sandbox-integration-api.meshconnect.com

# Coinbase's Mesh catalog integrationId (jumps Link straight to Coinbase
# login instead of showing the full provider catalog). Leave blank to show
# the catalog instead.
COINBASE_INTEGRATION_ID=47624467-e52e-4938-a41a-7926b6c27acf

# The test wallet address given in the take-home spec
DEST_WALLET_ADDRESS=0x0Ff0000f0A0f0000F0F000000000ffFf00f0F0f0
